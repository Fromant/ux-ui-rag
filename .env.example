# OpenRouter API Key (optional, for question generation without local LLM)
# Get free key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Local LLM URLs (for question generation with self-hosted models)
# Server 1 (default): http://172.29.128.1:8080
LOCAL_LLM_URL_1=http://172.29.128.1:8080
# Server 2 (optional, for round-robin parallel requests):
LOCAL_LLM_URL_2=http://192.168.0.9:8080

# LLaMA.cpp model name (for reference in logs)
LOCAL_LLM_MODEL=qwen3.5-5b-instruct

# Number of parallel workers (default: 4)
# Set to 2*number_of_servers for optimal parallelism
LOCAL_LLM_MAX_WORKERS=4
